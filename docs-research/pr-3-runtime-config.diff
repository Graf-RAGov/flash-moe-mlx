+        } else if ((c & 0xF0) == 0xE0 && i + 2 < len) {
+            // 3-byte UTF-8
+            s[out++] = s[i]; s[out++] = s[i+1]; s[out++] = s[i+2];
+            i += 3;
+        } else if ((c & 0xF8) == 0xF0 && i + 3 < len) {
+            // 4-byte UTF-8
+            s[out++] = s[i]; s[out++] = s[i+1]; s[out++] = s[i+2]; s[out++] = s[i+3];
+            i += 4;
+        } else {
+            s[out++] = s[i++];
+        }
+    }
+    s[out] = '\0';
+    return out;
+}
